## IMAGE BUTTON
screen FPE_Player_can_move_forward: 
    imagebutton:
        xanchor 0
        yanchor 0
        xpos 5
        ypos 250
        auto "buttonLEFT_%s.png"
        action Jump ("Turn_LEFT")

    imagebutton:
        xanchor 0
        yanchor 0
        xpos 720
        ypos 250
        auto "buttonRIGHT_%s.png"
        action Jump ("Turn_RIGHT")

    imagebutton:
        xanchor 0
        yanchor 0
        xpos 363
        ypos 350
        auto "buttonFORWARD_%s.png"
        action Jump ("Move_FORWARD")

screen FPE_Player_cannot_move_forward: 
    imagebutton:
        xanchor 0
        yanchor 0
        xpos 5
        ypos 250
        auto "buttonLEFT_%s.png"
        action Jump ("Turn_LEFT")

    imagebutton:
        xanchor 0
        yanchor 0
        xpos 720
        ypos 250
        auto "buttonRIGHT_%s.png"
        action Jump ("Turn_RIGHT")
