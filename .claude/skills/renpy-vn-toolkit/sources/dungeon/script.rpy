label player_and_npc_1:
    if player_position != npc_1_position:
        $ player_is_at_npc_1_position = False
    if player_position == npc_1_position:
        if player_is_at_npc_1_position != True:
            show npc_1_000_001
            "You met Mother at tile [npc_1_position]."
        $ player_is_at_npc_1_position = True

label FPE_movement:
    if player_cannot_move_forward == True:
        call screen FPE_Player_cannot_move_forward
    else:
        call screen FPE_Player_can_move_forward

label Turn_LEFT:
    if player_facing_direction == 1:
        $ player_facing_direction = 4
        jump FPE_calculate_position
    if player_facing_direction == 2:
        $ player_facing_direction = 1
        jump FPE_calculate_position
    if player_facing_direction == 3:
        $ player_facing_direction = 2
        jump FPE_calculate_position
    if player_facing_direction == 4:
        $ player_facing_direction = 3
        jump FPE_calculate_position

label Turn_RIGHT:
    if player_facing_direction == 1:
        $ player_facing_direction = 2
        jump FPE_calculate_position
    if player_facing_direction == 2:
        $ player_facing_direction = 3
        jump FPE_calculate_position
    if player_facing_direction == 3:
        $ player_facing_direction = 4
        jump FPE_calculate_position
    if player_facing_direction == 4:
        $ player_facing_direction = 1
        jump FPE_calculate_position

label Move_FORWARD:
    if player_facing_direction == 1:
        $ player_position -= 100
        jump FPE_calculate_position
    if player_facing_direction == 2:
        $ player_position += 1
        jump FPE_calculate_position
    if player_facing_direction == 3:
        $ player_position += 100
        jump FPE_calculate_position
    if player_facing_direction == 4:
        $ player_position -= 1
        jump FPE_calculate_position

label debug:
    pass

label game_over:
    return

