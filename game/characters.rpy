################################################################################
## Персонажи
##
## Единственное место определения персонажей игры.
## Реестр с описаниями — docs/01_characters.md (обновлять синхронно).
##
## Правила:
## - Отображаемые имена — только через _("…"): строка попадает в файлы
##   перевода и переводится через `translate <язык> strings`.
## - Переименование персонажа = правка одной строки в его базовом define.
## - Вариации имени (ласковые формы, прозвища) — отдельные Character
##   с kind=<база>: наследуют цвет и все свойства, меняется только имя.
## - В логике/сейвах сравнивать переменные и ключи, не отображаемые строки.
################################################################################

## Марина Александровна Шрайбер — главная героиня, рассказчица.
define mar = Character(_("Марина"), color="#b56576")

## Витя — муж Марины.
define vit = Character(_("Витя"), color="#5c7c9e")
## Ласковая форма имени.
define vit_d = Character(_("Витенька"), kind=vit)

## Настя — дочь Марины и Вити.
define nas = Character(_("Настя"), color="#c9a15a")
## Ласковая форма имени.
define nas_d = Character(_("Настенька"), kind=nas)

## Полли.
define pol = Character(_("Полли"), color="#7ba05b")

## Соседка.
define sos = Character(_("Соседка"), color="#8a7f8d")

## Психолог.
define psi = Character(_("Психолог"), color="#6f8f8f")
